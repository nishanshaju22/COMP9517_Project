   "source": [
    "from DeepLabV3.transformers import make_transforms\n",
    "\n",
    "train_tf_aug, val_tf = make_transforms(\n",
    "    augment=True,\n",
    "    img_size=IMAGE_SIZE\n",
    ")\n",
    "\n",
    "train_tf_base, _ = make_transforms(\n",
    "    augment=False,\n",
    "    img_size=IMAGE_SIZE\n",
    ")"
   ]
  },
